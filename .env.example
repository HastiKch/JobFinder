# Local scraper settings. Copy this file to .env on your machine.
# Do not commit .env or real tokens.

APIFY_API_TOKEN=apify_api_XXXXXXXXXXXX

# Required for job_fit_evaluator.py.
OPENAI_API_KEY=sk-REPLACE_ME

# Output modes: excel, google_sheets, or both.
# The full pipeline always writes to Google Sheets.
JOBSCRAPER_OUTPUT_MODE=excel

# Job sources: linkedin, indeed, stepstone, both, all, or comma-separated names.
JOBSCRAPER_SOURCES=linkedin

# Runtime settings. Lower concurrency values if provider rate limits are reached.
JOBSCRAPER_SEARCH_CONCURRENCY=15
JOBSCRAPER_APIFY_MEMORY_LIMIT_MB=0
JOBSCRAPER_APIFY_BATCH_SIZE=1
JOBSCRAPER_MAX_RESULTS_PER_SEARCH=500
JOBSCRAPER_SEARCH_WINDOW_BUFFER_SECONDS=3600
APIFY_RUN_MEMORY_MB=512
APIFY_RUN_TIMEOUT_SECONDS=3600
APIFY_CLIENT_TIMEOUT_SECONDS=120
APIFY_TRANSIENT_ERROR_RETRIES=5
APIFY_RETRY_DELAY_SECONDS=30
GOOGLE_API_TIMEOUT_SECONDS=120
GOOGLE_API_RETRIES=3
JOBFINDER_PIPELINE_STEP_TIMEOUT_SECONDS=21600
JOBSCRAPER_DELAY_BETWEEN_REQUESTS=0
JOBSCRAPER_SCRAPE_COMPANY_DETAILS=false
JOBSCRAPER_USE_INCOGNITO_MODE=true
JOBSCRAPER_SPLIT_BY_LOCATION=false

# Timezone used for terminal logs and new Excel/Google Sheets tab names.
JOBSCRAPER_TIMEZONE=Europe/Berlin

# Timezone used for the Posted date/time column.
JOBSCRAPER_POSTED_TIMEZONE=Europe/Berlin

# Optional locally. You can also save the ID in google_spreadsheet_id.txt.
GOOGLE_SPREADSHEET_ID=

# Preferred Google Sheets auth for local runs:
# save your service-account key as google_service_account.json.

# Indeed settings used when JOBSCRAPER_SOURCES includes indeed.
INDEED_COUNTRY=DE
INDEED_LOCATION=Germany
INDEED_MAX_RESULTS_PER_SEARCH=500
INDEED_MAX_CONCURRENCY=5
INDEED_SAVE_ONLY_UNIQUE_ITEMS=true

# Stepstone settings used when JOBSCRAPER_SOURCES includes stepstone.
STEPSTONE_LOCATION=deutschland
STEPSTONE_CATEGORY=
STEPSTONE_START_URLS=
STEPSTONE_MAX_RESULTS_PER_SEARCH=500
STEPSTONE_MAX_CONCURRENCY=10
STEPSTONE_MIN_CONCURRENCY=1
STEPSTONE_MAX_REQUEST_RETRIES=3
STEPSTONE_USE_APIFY_PROXY=true
STEPSTONE_APIFY_PROXY_GROUPS=RESIDENTIAL

# Job-fit evaluator settings.
# Source: excel or google_sheets. Leave blank to infer from configured files.
JOB_EVAL_SOURCE=
JOB_EVAL_SHEET=latest
JOB_EVAL_OPENAI_MODEL=gpt-5-mini
JOB_EVAL_BATCH_SIZE=40
JOB_EVAL_CONCURRENCY=8
JOB_EVAL_OPENAI_RETRIES=3
JOB_EVAL_OPENAI_TIMEOUT=120
JOB_EVAL_MAX_OUTPUT_TOKENS=9000
JOB_EVAL_CV_PDF_OUTPUT=true
JOB_EVAL_CV_PHOTO_FILE=cv/photo.jpg
JOB_EVAL_CV_PDF_TIMEOUT=120
JOB_EVAL_CV_DRIVE_PARENT_FOLDER=JobFinder
JOB_EVAL_LARGE_QUEUE_THRESHOLD=200
JOB_EVAL_LARGE_QUEUE_SLEEP_MS=2000
JOB_EVAL_SAVE_BATCH_SIZE=1
# Final output policy for Not Suitable rows:
# single_label_only keeps rows with exactly one unsuitable-reason label and
# removes the rest. keep_all preserves every evaluated row.
JOB_EVAL_UNSUITABLE_ROW_POLICY=single_label_only
